# Home Assistant local/runtime artifacts
home-assistant/.HA_VERSION
home-assistant/.cache/
home-assistant/.cloud/
home-assistant/.storage/
home-assistant/deps/
home-assistant/tts/
home-assistant/backups/
home-assistant/backup/
home-assistant/.ha_run.lock
home-assistant/*.log
home-assistant/*.log.*
home-assistant/*.db
home-assistant/*.db-*
home-assistant/secrets.yaml
home-assistant/backup.txt

# Home Assistant downloaded/frontend dependencies
home-assistant/custom_components/hacs/
home-assistant/www/community/

# Python cache
**/__pycache__/
*.pyc

# Local environment files
**/.env
!**/.env.example

# Docker app runtime data
app/*/.env
app/*/data/
app/*/backups/
app/*/library/
app/*/config/
app/*/consume/
app/*/export/
app/*/media/
